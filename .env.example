# Copy to .env — never commit real secrets.

DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@127.0.0.1:5432/grabpic
GCS_BUCKET=your-bucket-name

# Optional: prefix for POST /upload (default judge-uploads)
# GCS_UPLOAD_PREFIX=judge-uploads

# Optional: max bytes for POST /upload (default 10485760)
# MAX_UPLOAD_BYTES=10485760

FACE_DIST_THRESHOLD=0.6
SIGNED_URL_TTL_SECONDS=900
